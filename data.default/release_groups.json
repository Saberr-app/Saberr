        "Erai-raws": {
            "submitter": "Erai-raws",
            "unique_filter": {
                "startswith": "[Erai-raws]"
            },
            "regex": [
                {
                    "pattern": "^\\[(?P<release_group>[^\\]]+)\\]\\s+(?P<title>.+?)\\s*-\\s*(?P<episode_number>\\d+)(?:v(?P<version_number>\\d+))?(?:\\s*\\((?P<language_code>[A-Za-z]{1,3})\\))?(?:\\s*\\((?P<repack_indicator>REPACK)\\))?\\s*\\[(?P<resolution>\\d+p)\\s+(?P<source>[A-Z]+)\\s.*\\s(?P<encoding>HEVC|AVC|AV1)",
                    "required_pattern_groups": [
                        "release_group",
                        "title",
                        "episode_number"
                    ]
                }
            ],
            "default_encoding": "AVC",
            "default_resolution": "1080p",
            "default_language_code": "JP",
            "batch_keyword": "[BATCH]",
            "episode_numbering_affinity": "STRICT"
        },
